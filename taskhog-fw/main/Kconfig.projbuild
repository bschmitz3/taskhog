menu "Taskhog"

    config TASKHOG_WIFI_SSID
        string "Wi-Fi SSID (M3: rede fixa)"
        default ""
        help
            SSID da rede usada para sincronizar com o Hub. Vazio = sync desligado
            (o device continua gravando offline normalmente).

    config TASKHOG_WIFI_PASSWORD
        string "Wi-Fi password"
        default ""
        help
            Senha WPA2. Vazio = rede aberta.

    config TASKHOG_HUB_URL
        string "Hub base URL"
        default "https://hub.taskhog.win"
        help
            Base do Hub (sem barra final). Ex.: https://hub.taskhog.win ou
            http://192.168.100.227:8088.

    config TASKHOG_DEVICE_TOKEN
        string "Device bearer token"
        default ""
        help
            Token enviado em Authorization: Bearer. Deve casar com device_tokens
            no hub.yaml.

    config TASKHOG_SYNC_MAX_ATTEMPTS
        int "Máx. tentativas de upload antes de marcar erro"
        default 5
        range 1 50

    config TASKHOG_DEEP_SLEEP_ENABLE
        bool "Enable deep sleep (portable / battery mode)"
        default n
        help
            Quando ativo, o device entra em deep sleep após ficar IDLE.
            Deixe desligado para desenvolvimento via USB com monitor serial.

    config TASKHOG_DEEP_SLEEP_SKIP_ON_USB
        bool "Skip auto sleep while USB is connected"
        default y
        depends on TASKHOG_DEEP_SLEEP_ENABLE

    config TASKHOG_DEEP_SLEEP_IDLE_SEC
        int "Seconds in IDLE before deep sleep"
        default 15
        range 3 300
        depends on TASKHOG_DEEP_SLEEP_ENABLE

    config TASKHOG_DEEP_SLEEP_TIMER_MIN
        int "Internal timer wake interval (minutes)"
        default 60
        range 1 1440
        depends on TASKHOG_DEEP_SLEEP_ENABLE

endmenu
